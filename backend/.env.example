# Copy this file to backend/.env and fill in your values.
# backend/.env is git-ignored and must never be committed.

# --- OpenAI (used from Phase 4 onward; safe to leave blank for Phase 1) ---
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_CUT_MODEL=gpt-4o

# --- Local storage ---
# Base folder where projects, cache, logs, and the SQLite DB live.
APP_DATA_DIR=~/.local_ai_video_editor

# Optional: override the database location/backend.
# Defaults to a SQLite file inside APP_DATA_DIR when unset.
# DATABASE_URL=sqlite:////absolute/path/to/shelfedit.db

# --- Import limits ---
MAX_IMPORT_FILE_GB=30

# --- Client (desktop/web) origins allowed to call this local server ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
